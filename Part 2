import os
import glob
import numpy as np
import torch
from torch.utils.data import Dataset
from PIL import Image
import torchvision.transforms as T
from .config import Config

class UnpairedISPDataset(Dataset):
    def __init__(self, root_dir, mode='train'):
        self.mode = mode
        self.patch_size = Config.PATCH_SIZE
        
        self.raw_paths = sorted(glob.glob(os.path.join(root_dir, mode, 'raws', '*.npy')))
        self.rgb_paths = sorted(glob.glob(os.path.join(root_dir, mode, 'jpegs', '*.*')))
        
        self.len_raw = len(self.raw_paths)
        self.len_rgb = len(self.rgb_paths)
        self.length = max(self.len_raw, self.len_rgb)

    def __len__(self):
        return self.length

    def pack_raw(self, raw):
        # Input: (H, W) -> Output: (4, H/2, W/2)
        # Packing pattern: R, Gr, Gb, B
        im = raw
        H, W = im.shape
        if H % 2 != 0 or W % 2 != 0:
            im = im[:H//2*2, :W//2*2]
            
        out = np.stack((im[0::2, 0::2], im[0::2, 1::2], 
                        im[1::2, 0::2], im[1::2, 1::2]), axis=0)
        return out

    def normalize_raw(self, raw):
        return np.clip((raw - Config.BLACK_LEVEL) / (Config.WHITE_LEVEL - Config.BLACK_LEVEL), 0, 1)

    def __getitem__(self, idx):
        # 1. Load RAW
        idx_raw = idx % self.len_raw
        raw = np.load(self.raw_paths[idx_raw]).astype(np.float32)
        
        # Random Crop RAW
        H, W = raw.shape
        if H > self.patch_size and W > self.patch_size:
            xx = np.random.randint(0, W - self.patch_size)
            yy = np.random.randint(0, H - self.patch_size)
            raw = raw[yy:yy+self.patch_size, xx:xx+self.patch_size]
        
        raw = self.normalize_raw(raw)
        raw_tensor = torch.from_numpy(self.pack_raw(raw)).float()
        
        # 2. Load Target RGB
        idx_rgb = np.random.randint(0, self.len_rgb)
        rgb = Image.open(self.rgb_paths[idx_rgb]).convert('RGB')
        
        target_size = self.patch_size * 2
        transform = T.Compose([
            T.Resize(int(target_size * 1.2)),
            T.RandomCrop(target_size),
            T.RandomHorizontalFlip(),
            T.ToTensor()
        ])
        rgb_tensor = transform(rgb)
        
        return {"raw": raw_tensor, "rgb": rgb_tensor}
EOF

