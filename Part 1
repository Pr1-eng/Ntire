echo "📊 Generating plot_logs.py..."
cat << 'EOF' > NTIRE26_ISP/plot_logs.py
import matplotlib.pyplot as plt
import re
import argparse
import os

def parse_log(file_path):
    batch_data = {'iter': [], 'g_loss': [], 'd_loss': []}
    batch_pattern = re.compile(r"\[Ep (\d+)\]\[Bt (\d+)/\d+\] .*? G: ([\d\.]+) \| D: ([\d\.]+)")
    
    current_iter = 0
    with open(file_path, 'r') as f:
        for line in f:
            match = batch_pattern.search(line)
            if match:
                batch_data['iter'].append(current_iter)
                batch_data['g_loss'].append(float(match.group(3)))
                batch_data['d_loss'].append(float(match.group(4)))
                current_iter += 1
    return batch_data

def plot_dashboard(data, save_path):
    plt.figure(figsize=(10, 6))
    plt.plot(data['iter'], data['g_loss'], alpha=0.5, color='green', label='Generator')
    plt.plot(data['iter'], data['d_loss'], alpha=0.5, color='red', label='Discriminator')
    plt.title("Training Loss")
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.savefig(save_path)
    print(f"✅ Saved graph to {save_path}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--log", required=True)
    parser.add_argument("--out", default="training_plot.png")
    args = parser.parse_args()
    data = parse_log(args.log)
    if data['iter']: plot_dashboard(data, args.out)
EOF

