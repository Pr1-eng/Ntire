# 6. Create model.py
cat <<EOT > model.py
import torch
import torch.nn as nn

class ResidualBlock(nn.Module):
    def __init__(self, channels):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv2d(channels, channels, 3, padding=1, bias=False),
            nn.InstanceNorm2d(channels),
            nn.ReLU(inplace=True),
            nn.Conv2d(channels, channels, 3, padding=1, bias=False),
            nn.InstanceNorm2d(channels)
        )
    def forward(self, x): return x + self.conv(x)

class ISPNet(nn.Module):
    def __init__(self):
        super().__init__()
        # Input: 4-channel Bayer (RGGB)
        self.head = nn.Sequential(
            nn.Conv2d(4, 64, 3, padding=1),
            nn.ReLU(inplace=True)
        )
        # Body: 8 Residual Blocks
        self.body = nn.Sequential(*[ResidualBlock(64) for _ in range(8)])
        
        # Tail: Upsample x2 to match original resolution
        self.tail = nn.Sequential(
            nn.ConvTranspose2d(64, 64, 4, stride=2, padding=1),
            nn.ReLU(inplace=True),
            nn.Conv2d(64, 3, 3, padding=1),
            nn.Sigmoid() # Output [0, 1]
        )

    def forward(self, x):
        feat = self.head(x)
        res = self.body(feat)
        out = self.tail(res)
        return out
EOT
echo "[✔] Created model.py"

# 7. Create train_dist.py (Multi-GPU Main Script)
cat <<EOT > train_dist.py
import os
import json
import torch
import torch.nn as nn
import torch.distributed as dist
from torch.nn.parallel import DistributedDataParallel as DDP
from torch.utils.data.distributed import DistributedSampler
from torch.utils.data import DataLoader
from datetime import datetime
import logging
from tqdm import tqdm
import sys

from dataset import NTIREDataset
from model import ISPNet 

def setup_dist(rank, world_size):
    os.environ['MASTER_ADDR'] = 'localhost'
    os.environ['MASTER_PORT'] = '12355'
    dist.init_process_group("nccl", rank=rank, world_size=world_size)
    torch.cuda.set_device(rank)

def cleanup():
    dist.destroy_process_group()

def train(rank, world_size):
    # Load Config
    with open('config.json', 'r') as f:
        cfg = json.load(f)

    setup_dist(rank, world_size)

    # Setup Logging (Rank 0 Only)
    if rank == 0:
        os.makedirs(cfg['paths']['log_dir'], exist_ok=True)
        os.makedirs(cfg['paths']['checkpoint_dir'], exist_ok=True)
        
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        log_file = os.path.join(cfg['paths']['log_dir'], f"train_{timestamp}.log")
        
        logging.basicConfig(
            filename=log_file,
            level=logging.INFO,
            format='%(asctime)s - %(message)s',
            datefmt='%Y-%m-%d %H:%M:%S'
        )
        print(f"Logging to: {log_file}")

    # Model Setup
    model = ISPNet().to(rank)
    model = DDP(model, device_ids=[rank])
    optimizer = torch.optim.Adam(model.parameters(), lr=cfg['training']['lr'])
    criterion = nn.L1Loss() 

    # Resume Logic
    start_epoch = 1
    if cfg['training']['resume']['enable']:
        ckpt_path = cfg['training']['resume']['checkpoint_path']
        if os.path.isfile(ckpt_path):
            if rank == 0: print(f"Resuming from: {ckpt_path}")
            checkpoint = torch.load(ckpt_path, map_location=f'cuda:{rank}')
            model.module.load_state_dict(checkpoint['model_state_dict'])
            optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
            start_epoch = checkpoint['epoch'] + 1
        else:
            if rank == 0: print(f"Checkpoint not found. Starting from scratch.")

    # Data Loading
    dataset = NTIREDataset(cfg['paths']['input_raw'], cfg['paths']['input_dslr'])
    if len(dataset) == 0:
        if rank == 0: print("Error: Dataset is empty. Check data paths.")
        cleanup()
        return

    sampler = DistributedSampler(dataset, num_replicas=world_size, rank=rank)
    loader = DataLoader(dataset, batch_size=cfg['training']['batch_size'], 
                        sampler=sampler, num_workers=4, pin_memory=True)

    if rank == 0: print(f"Starting training on {world_size} GPUs...")
    
    for epoch in range(start_epoch, cfg['training']['epochs'] + 1):
        sampler.set_epoch(epoch)
        model.train()
        epoch_loss = 0.0

        if rank == 0:
            pbar = tqdm(loader, desc=f"Epoch {epoch}", leave=False)
        else:
            pbar = loader

        for raw, dslr in pbar:
            raw, dslr = raw.to(rank), dslr.to(rank)

            optimizer.zero_grad()
            output = model(raw)
            loss = criterion(output, dslr)
            loss.backward()
            optimizer.step()

            epoch_loss += loss.item()
            if rank == 0:
                pbar.set_postfix(loss=loss.item())

        if rank == 0:
            avg_loss = epoch_loss / len(loader)
            logging.info(f"Epoch: {epoch} | Loss: {avg_loss:.6f}")
            
            if epoch % cfg['training']['save_freq'] == 0:
                save_path = os.path.join(cfg['paths']['checkpoint_dir'], f"isp_epoch_{epoch:04d}.pth")
                torch.save({
                    'epoch': epoch,
                    'model_state_dict': model.module.state_dict(),
                    'optimizer_state_dict': optimizer.state_dict(),
                    'loss': avg_loss
                }, save_path)
                logging.info(f"Saved Checkpoint: {save_path}")

    cleanup()

if __name__ == "__main__":
    if not torch.cuda.is_available():
        print("Error: CUDA not found. Training requires GPU.")
        sys.exit(1)
        
    world_size = torch.cuda.device_count()
    torch.multiprocessing.spawn(train, args=(world_size,), nprocs=world_size, join=True)
EOT
echo "[✔] Created train_dist.py"

# 8. Create visualize_logs.py
cat <<EOT > visualize_logs.py
import matplotlib.pyplot as plt
import argparse
import re

def plot_logs(log_path):
    epochs = []
    losses = []
    pattern = re.compile(r"Epoch:\s+(\d+)\s+\|\s+Loss:\s+([0-9.]+)")

    print(f"Reading: {log_path}")
    with open(log_path, 'r') as f:
        for line in f:
            match = pattern.search(line)
            if match:
                epochs.append(int(match.group(1)))
                losses.append(float(match.group(2)))

    if not epochs:
        print("No valid data found in log file.")
        return

    plt.figure(figsize=(10, 6))
    plt.plot(epochs, losses, label='Training Loss', color='b', linewidth=2)
    plt.xlabel('Epochs')
    plt.ylabel('Loss (L1)')
    plt.title(f'Training Progress')
    plt.grid(True, linestyle='--', alpha=0.7)
    plt.legend()
    plt.savefig(log_path.replace('.log', '.png'))
    print(f"Graph saved as .png")

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument('--log_path', type=str, required=True)
    args = parser.parse_args()
    plot_logs(args.log_path)
EOT
echo "[✔] Created visualize_logs.py"

