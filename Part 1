# 5. Create dataset.py
cat <<EOT > dataset.py
import torch
import numpy as np
import glob
import os
from torch.utils.data import Dataset
from PIL import Image

class NTIREDataset(Dataset):
    def __init__(self, raw_path, dslr_path):
        self.raw_files = sorted(glob.glob(os.path.join(raw_path, "*.npy")))
        self.dslr_files = sorted(glob.glob(os.path.join(dslr_path, "*.jpg")))
        
        if not self.raw_files:
            print(f"WARNING: No .npy files found in {raw_path}")
        if not self.dslr_files:
            print(f"WARNING: No .jpg files found in {dslr_path}")
            
        self.len = max(len(self.raw_files), len(self.dslr_files)) if self.raw_files and self.dslr_files else 0

    def __len__(self):
        return self.len

    def __getitem__(self, idx):
        raw_idx = idx % len(self.raw_files)
        dslr_idx = idx % len(self.dslr_files)

        # Load 10-bit Bayer [H, W] -> Normalize to [0, 1]
        try:
            raw_data = np.load(self.raw_files[raw_idx]).astype(np.float32) / 1023.0
        except Exception as e:
            print(f"Error loading {self.raw_files[raw_idx]}: {e}")
            return torch.zeros(4, 256, 256), torch.zeros(3, 512, 512)

        # Pixel Unshuffle: [H, W] -> [4, H/2, W/2]
        H, W = raw_data.shape
        raw_stack = np.zeros((4, H//2, W//2), dtype=np.float32)
        raw_stack[0] = raw_data[0::2, 0::2] # R
        raw_stack[1] = raw_data[0::2, 1::2] # G1
        raw_stack[2] = raw_data[1::2, 0::2] # G2
        raw_stack[3] = raw_data[1::2, 1::2] # B
        
        # Load DSLR
        try:
            dslr_img = Image.open(self.dslr_files[dslr_idx]).convert('RGB')
            dslr_data = np.array(dslr_img).astype(np.float32) / 255.0
            dslr_tensor = torch.from_numpy(dslr_data).permute(2, 0, 1)
        except Exception as e:
            print(f"Error loading {self.dslr_files[dslr_idx]}: {e}")
            return torch.from_numpy(raw_stack), torch.zeros(3, H, W)

        return torch.from_numpy(raw_stack), dslr_tensor
EOT
